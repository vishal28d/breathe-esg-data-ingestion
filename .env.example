# Example Environment Variables

# ==============================================================
# FRONTEND (.env)
# Place this file at: frontend/.env
# ==============================================================
# This tells the React app where to send API requests.
# Locally, it defaults to http://localhost:8000/api/ if not set.
# In production (Vercel), you MUST set this in the Vercel dashboard:
VITE_API_BASE_URL=https://breathe-backend-xxxx.onrender.com/api/


# ==============================================================
# BACKEND (.env)
# Place this file at: .env (root directory)
# ==============================================================
# Note: You DO NOT need these for local development. 
# The Django app falls back to safe local defaults (SQLite, localhost).
# In production (Render), these are handled AUTOMATICALLY by render.yaml.

# DATABASE_URL=postgres://user:pass@host:5432/db
# SECRET_KEY=your-super-secret-key
# DEBUG=False
# ALLOWED_HOSTS=breathe-backend-xxxx.onrender.com
# CORS_ALLOW_ALL_ORIGINS=True
